<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ tag_label }} - 全球动态</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro SC", "PingFang SC", "Noto Sans SC", "Helvetica Neue", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    background: #f5f5f7; color: #1d1d1f; line-height: 1.5;
  }
  a { color: inherit; text-decoration: none; }
  :root {
    --radius-sm: 6px; --color-accent: #0071e3; --color-muted: #86868b;
    --max-width: 1440px; --header-h: 52px;
  }
  .header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(29,29,31,0.97);
    backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .header-inner {
    max-width: var(--max-width); margin: 0 auto; padding: 0 32px;
    height: var(--header-h); display: flex; align-items: center;
    justify-content: space-between;
  }
  .header-left { display: flex; align-items: center; gap: 12px; }
  .back-btn {
    width: 30px; height: 30px; border-radius: 6px;
    background: rgba(255,255,255,0.08); border: none; color: #fff;
    font-size: 15px; cursor: pointer; display: flex; align-items: center; justify-content: center;
  }
  .back-btn:hover { background: rgba(255,255,255,0.15); }
  .page-title { color: #fff; font-size: 16px; font-weight: 600; }
  .header-date { display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.6); font-size: 12px; }
  .header-date .lunar { color: rgba(255,255,255,0.4); }
  .container { max-width: var(--max-width); margin: 0 auto; padding: 20px 32px 60px; }
  .section-meta { font-size: 14px; color: var(--color-muted); margin-bottom: 16px; padding: 0 4px; }
  .news-list { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .news-item {
    display: flex; gap: 14px; padding: 12px 14px;
    background: #ffffff; border-radius: var(--radius-sm);
    cursor: pointer; transition: background 0.15s;
    border-bottom: 1px solid #f0f0f2; align-items: flex-start;
  }
  .news-item:hover { background: #f8f8fa; }
  .news-item:last-child { border-bottom: none; }
  .news-thumb {
    width: 72px; height: 72px; border-radius: var(--radius-sm);
    flex-shrink: 0; overflow: hidden; position: relative;
  }
  .news-thumb .list-tag {
    position: absolute; top: 4px; left: 4px;
    padding: 1px 6px; border-radius: 3px; font-size: 9px; font-weight: 600;
    color: #fff; letter-spacing: 0.2px;
  }
  .news-content { flex: 1; min-width: 0; }
  .news-source { display: flex; align-items: center; gap: 5px; margin-bottom: 3px; }
  .news-source-icon { width: 14px; height: 14px; border-radius: 3px; display: inline-flex; align-items: center; justify-content: center; font-size: 7px; color: #fff; flex-shrink: 0; }
  .news-source-name { font-size: 11px; font-weight: 600; color: var(--color-muted); letter-spacing: 0.3px; }
  .news-title { font-size: 14px; font-weight: 600; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; color: #1d1d1f; margin-bottom: 2px; }
  .news-summary { font-size: 12px; color: var(--color-muted); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .news-time { font-size: 11px; color: #a1a1a6; margin-top: 4px; }
  .pagination { text-align: center; padding: 24px 0 40px; grid-column: 1 / -1; }
  .pagination a { display: inline-block; padding: 8px 20px; border: 1px solid #d2d2d7; border-radius: 20px; background: #fff; color: #1d1d1f; font-size: 14px; font-weight: 500; cursor: pointer; margin: 0 4px; transition: all 0.2s; }
  .pagination a:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .pagination a.active { background: #1d1d1f; color: #fff; border-color: #1d1d1f; }
  .footer { background: #1d1d1f; color: rgba(255,255,255,0.4); padding: 28px 32px; text-align: center; font-size: 12px; line-height: 1.8; }
  @media (max-width: 640px) {
    .container { padding: 14px 14px 40px; }
    .header-inner { padding: 0 14px; }
    .header-date { font-size: 10px; }
    .header-date .lunar { display: none; }
    .news-list { grid-template-columns: 1fr; gap: 6px; }
    .news-thumb { width: 64px; height: 64px; }
    .news-title { font-size: 13px; }
    .news-item { padding: 10px 12px; }
  }
</style>
</head>
<body>

<header class="header">
  <div class="header-inner">
    <div class="header-left">
      <button class="back-btn" onclick="location.href='{{ back_url }}'">←</button>
      <span class="page-title">{{ tag_label }}</span>
    </div>
    <div class="header-date">
      <span>{{ date_str }}</span><span> · </span><span>{{ week_str }}</span><span> · </span><span class="lunar">农历{{ lunar_str }}</span>
    </div>
  </div>
</header>

<main class="container">
  <div class="section-meta">共 {{ total }} 条内容</div>
  <div class="news-list">
    {% for item in items %}
    <a class="news-item" href="{{ item.url }}" target="_blank" rel="noopener">
      <div class="news-thumb" style="background:linear-gradient(135deg,#e2e8f0,#cbd5e1);{% if item.thumbnail_url %}background-image:url(&quot;{{ item.thumbnail_url }}&quot;);background-size:cover;background-position:center{% endif %}">
        <span class="list-tag" style="background:{{ tag_color }};">{{ tag_key }}</span>
      </div>
      <div class="news-content">
        <div class="news-source">
          <span class="news-source-icon" style="background:{{ item.source_color }};">{{ item.source_icon }}</span>
          <span class="news-source-name">{{ item.source_name }}</span>
        </div>
        <div class="news-title">{{ item.title }}</div>
        <div class="news-summary">{{ item.summary[:80] }}</div>
        <div class="news-time">{{ item.time_ago }}</div>
      </div>
    </a>
    {% endfor %}
  </div>
  <div class="pagination">
    {% if page > 1 %}
    <a href="./{{ page - 1 }}.html">← 上一页</a>
    {% endif %}
    {% for p in range(1, total_pages + 1) %}
    <a href="./{{ 'index.html' if p == 1 else p ~ '.html' }}" class="{{ 'active' if p == page }}">{{ p }}</a>
    {% endfor %}
    {% if page < total_pages %}
    <a href="./{{ page + 1 }}.html">下一页 →</a>
    {% endif %}
  </div>
</main>

<div class="footer">
  <p>🌐 全球AI·科技·财经动态 — 智能聚合 · 每日更新</p>
</div>
</body>
</html>